POSTGRES_DB=kb
POSTGRES_USER=kb
POSTGRES_PASSWORD=kb
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://kb:kb@postgres:5432/kb
APP_ENV=development
API_PORT=8000
CONNECTOR_TOKEN_ENCRYPTION_KEY=
SESSION_ENCRYPTION_KEY=
# CONNECTOR_TOKEN_ENCRYPTION_KEY and SESSION_ENCRYPTION_KEY may use development fallbacks only when APP_ENV=development.
# Set both explicitly for staging and production deployments.
WORKER_POLL_SECONDS=2
WORKER_MAX_ATTEMPTS=5
WORKER_IDLE_SLEEP_SECONDS=2
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_MAX_INPUT_TOKENS=8192
EMBEDDING_REQUEST_MAX_TOTAL_TOKENS=6000
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_API_KEY=replace-me
EMBEDDING_BASE_URL=
GENERATION_MODEL=
GENERATION_BASE_URL=
GENERATION_API_KEY=
GENERATION_TEMPERATURE=0.0
GENERATION_TIMEOUT_SECONDS=90
GENERATION_REFERENCE_LIMIT=8
GENERATION_SEARCH_LIMIT=12
CHUNK_TARGET_TOKENS=600
CHUNK_MAX_TOKENS=800
CHUNK_OVERLAP_TOKENS=80
SEARCH_VECTOR_CANDIDATES=40
SEARCH_KEYWORD_CANDIDATES=40
SEARCH_RRF_K=60
SEARCH_DEFAULT_LIMIT=10
SEARCH_MAX_LIMIT=50
